{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run docs:build:desktop && vite",
    "dev:all": "concurrently \"npm run docs:build:desktop && vite\" \"vitepress dev docs\"",
    "dev:web": "cross-env VITE_BUILD_TARGET=web vitepress build docs --base /products/text-hunter/docs/ && vite",
    "build": "vite build && npm run docs:build:desktop",
    "build:web": "vite build --mode production && npm run docs:build:web",
    "build:desktop": "vite build && npm run docs:build:desktop",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:build:desktop": "vitepress build docs",
    "docs:build:web": "cross-env VITE_BUILD_TARGET=web vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "update-api": "openapi-typescript http://localhost:8000/openapi.json -o src/api/schema.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.10.1",
    "dexie": "^4.2.1",
    "pdfjs-dist": "^5.4.530",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^7.0.3",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.12.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.2"
  }
}
