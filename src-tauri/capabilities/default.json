{
  "$schema": "gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for TextHunter",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:*"
        },
        {
          "url": "http://127.0.0.1:*"
        }
      ]
    }
  ]
}
